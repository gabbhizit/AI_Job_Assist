# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key
AI_PROVIDER=claude

# Job APIs
# SerpAPI — primary job source (Google Jobs aggregator). Sign up at serpapi.com
SERPAPI_KEY=your_serpapi_key
# The Muse — free supplemental tech jobs source. Optional key for higher rate limits.
THE_MUSE_API_KEY=
# Adzuna — free secondary source. Sign up at developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# JSearch (RapidAPI) — optional fallback. Only runs if this key is present.
RAPIDAPI_KEY=

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
ADMIN_EMAIL=your_email@example.com

# Cron Secret
CRON_SECRET=your_cron_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
